{
  "name": "YouTrack TimeTracker",
  "description": "Convenient TimeTracker app integrated with YouTrack",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "16": "icons/main.png",
    "48": "icons/main.png",
    "128": "icons/main.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Open YT TimeTracker"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://youtrack-mapps.sovcombank.ru/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  }
}
